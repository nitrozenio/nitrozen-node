{
  "name": "nitrozenio",
  "version": "1.0.0",
  "description": "Official Node.js SDK for the Nitrozen.io changelog API.",
  "license": "MIT",
  "author": "Nitrozen.io",
  "homepage": "https://nitrozen.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/nitrozenio/nitrozen-node.git"
  },
  "keywords": [
    "nitrozen",
    "changelog",
    "api",
    "sdk",
    "client"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "babel src -d dist",
    "prepare": "npm run build",
    "test": "mocha"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3"
  },
  "browser": {
    "fs": false
  },
  "dependencies": {
    "superagent": "^10.2.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.0.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/register": "^7.0.0",
    "expect.js": "^0.3.1",
    "mocha": "^11.0.0",
    "sinon": "^21.0.0"
  }
}
